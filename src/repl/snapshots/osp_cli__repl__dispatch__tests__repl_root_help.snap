source: src/repl/dispatch.rs
assertion_line: 529
expression: help
---
 Usage:  [INVOCATION_OPTIONS] COMMAND [ARGS]...

- Commands -
  exit        Exit application.
  help        Show this command overview.
  options     per invocation: --format/--json/--table/--value/--md, --mode, --color, --unicode/--ascii, -v/-q/-d, --cache, --plugin-provider
  plugins     subcommands: list, commands, enable, disable, doctor
  doctor      subcommands: all, config, last, plugins, theme
  theme       subcommands: list, show, use
  config      subcommands: show, get, explain, set, doctor
  history     subcommands: list, prune, clear
