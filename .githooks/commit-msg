#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:?commit message file is required}"

clean_file="$(mktemp)"
trap 'rm -f "$clean_file"' EXIT
sed '/^#/d' "$msg_file" > "$clean_file"

subject_line="$(awk 'NF{print NR; exit}' "$clean_file" || true)"
subject=""
if [[ -n "$subject_line" ]]; then
    subject="$(sed -n "${subject_line}p" "$clean_file")"
fi

if [[ -z "$subject" ]]; then
    echo "ERROR: Empty commit message subject."
    exit 1
fi

# Allow Git-generated commit subjects and local autosquash workflow.
if [[ "$subject" =~ ^(Merge|Revert)\  ]] || [[ "$subject" =~ ^(fixup!|squash!)\  ]]; then
    exit 0
fi

if ((${#subject} > 72)); then
    echo "ERROR: Subject line is longer than 72 characters (${#subject})."
    echo "       Subject: $subject"
    exit 1
fi

if [[ "$subject" =~ \.$ ]]; then
    echo "ERROR: Subject line must not end with a period."
    exit 1
fi

# Conventional + project rule:
# <type>(<scope>): <Subject>
# scope is optional; if present it must be lowercase and kebab/snake/path style.
pattern='^(feat|fix|docs|refactor|test|chore|style|ci|build|perf|revert)(\([a-z0-9][a-z0-9._/-]*\))?: [A-Z].+$'
if ! [[ "$subject" =~ $pattern ]]; then
    cat <<'EOF'
ERROR: Invalid commit subject format.

Expected:
  <type>(<scope>): <Subject>

Allowed <type>:
  feat, fix, docs, refactor, test, chore, style, ci, build, perf, revert

Examples:
  feat(cli): Add plugin doctor command
  fix(config): Normalize profile identifiers
  docs(roadmap): Update phase checklist
EOF
    echo "Got:"
    echo "  $subject"
    exit 1
fi

# Reject the common mistake of embedding literal "\n" inside a single -m
# argument instead of using the editor or multiple -m flags.
if grep -q '\\n' "$clean_file"; then
    cat <<'EOF'
ERROR: Commit message contains literal "\n" sequences.

Use your editor or multiple -m flags, for example:
  git commit -m "type(scope): Subject" -m "Why..." -m "What..."
EOF
    exit 1
fi

body_start=$((subject_line + 1))
next_line="$(sed -n "${body_start}p" "$clean_file")"

if [[ -n "${next_line}" ]]; then
    echo "ERROR: Commit body must be separated from the subject by one blank line."
    exit 1
fi

body="$(tail -n +"$((subject_line + 2))" "$clean_file" || true)"
meaningful_body="$(
    printf '%s\n' "$body" \
        | sed '/^[[:space:]]*$/d' \
        | grep -Ev '^(Why|What|Verification|Refs):[[:space:]]*$|^-[[:space:]]*$' \
        || true
)"

if [[ -z "$meaningful_body" ]]; then
    cat <<'EOF'
ERROR: Commit messages must include a real body.

Use the body to explain:
  - why the change exists
  - what changed
  - how you verified it
EOF
    exit 1
fi

overlong_line="$(
    awk -v start="$((subject_line + 2))" '
        NR >= start && length($0) > 80 {
            printf "%d:%d:%s\n", NR, length($0), $0;
            exit 0;
        }
    ' "$clean_file"
)"

if [[ -n "$overlong_line" ]]; then
    line_no="${overlong_line%%:*}"
    rest="${overlong_line#*:}"
    line_len="${rest%%:*}"
    line_text="${rest#*:}"
    echo "ERROR: Commit body lines must be 80 characters or fewer."
    echo "       Line $line_no has length $line_len."
    echo "       $line_text"
    exit 1
fi

exit 0
